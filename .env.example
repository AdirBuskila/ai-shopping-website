# ── Copy this file to .env and fill in your OpenAI key ──────────────────────
#   cp .env.example .env    (then edit .env)
# .env is gitignored and will never be committed.

# OpenAI (chat assistant + embeddings) — REQUIRED
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_CHAT_MODEL=gpt-4o-mini          # bump to gpt-4o for stronger answers
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Chat guardrail
CHAT_PROMPT_LIMIT=5

# MySQL (values are the docker-compose defaults)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=shopdb
MYSQL_USER=shop
MYSQL_PASSWORD=shop
# In Docker use host "mysql"; running the backend locally use "localhost"
DATABASE_URL=mysql+pymysql://shop:shop@mysql:3306/shopdb

# Redis (cache + 5-prompt counter + vector index)
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440
